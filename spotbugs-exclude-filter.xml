<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!-- JPA 엔티티 기본 생성자 -->
    <Match>
        <Class name="~allmart\.productservice\.domain\..*"/>
        <Bug pattern="EQ_DOESNT_OVERRIDE_EQUALS"/>
    </Match>
    <!-- Spring Security 설정 클래스 -->
    <Match>
        <Class name="~allmart\.productservice\.config\..*"/>
        <Bug pattern="THROWS_METHOD_THROWS_CLAUSE_BASIC_EXCEPTION"/>
    </Match>
    <!-- AnthropicTaxClassifier text block: SpotBugs가 텍스트 블록 개행을 \n으로 오탐 -->
    <Match>
        <Class name="allmart.productservice.adapter.client.AnthropicTaxClassifier"/>
        <Bug pattern="VA_FORMAT_STRING_USES_NEWLINE"/>
    </Match>
    <!--
        JPA 엔티티 간 관계 참조 저장 — orm.xml로 @ManyToOne 이동 후 SpotBugs가 JPA 관계임을 인식 못함.
        JPA 엔티티 참조를 방어 복사하면 세션 캐시/동일성 보장이 깨지므로 정상 패턴.
    -->
    <Match>
        <Class name="~allmart\.productservice\.domain\..*"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
    <!-- AnthropicRequest/Response는 외부 API DTO — List 불변화보다 가독성 우선 -->
    <Match>
        <Class name="~allmart\.productservice\.adapter\.client\.dto\..*"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
    <Match>
        <Class name="~allmart\.productservice\.adapter\.client\.dto\..*"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
</FindBugsFilter>
