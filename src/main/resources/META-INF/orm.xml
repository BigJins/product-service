<?xml version="1.0" encoding="UTF-8"?>
<entity-mappings xmlns="https://jakarta.ee/xml/ns/persistence/orm"
                 xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                 xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence/orm
                                     https://jakarta.ee/xml/ns/persistence/orm/orm_3_1.xsd"
                 version="3.1">

    <!--
        JPA 컬럼/테이블/관계 매핑을 XML로 분리 — 도메인 클래스 가독성 향상.
        @Entity, @Id, @SnowflakeGenerated, @CreatedDate, @EntityListeners 는 Java에 유지:
          - @Id + @SnowflakeGenerated: 커스텀 Hibernate BeforeExecutionGenerator (XML 표현 불가)
          - @CreatedDate + @EntityListeners: Spring Data Auditing 전용 (JPA XML 미지원)
    -->

    <entity class="allmart.productservice.domain.product.Product">
        <table name="tbl_product"/>
        <attributes>
            <many-to-one name="category" fetch="LAZY" optional="false">
                <join-column name="category_id" nullable="false"/>
            </many-to-one>
            <basic name="name">
                <column nullable="false"/>
            </basic>
            <basic name="description">
                <column column-definition="TEXT"/>
            </basic>
            <basic name="sellingPrice">
                <column nullable="false"/>
            </basic>
            <basic name="purchasePrice">
                <column nullable="false"/>
            </basic>
            <basic name="taxType">
                <column nullable="false"/>
                <enumerated>STRING</enumerated>
            </basic>
            <basic name="imageUrl">
                <column nullable="false"/>
            </basic>
            <basic name="status">
                <column nullable="false"/>
                <enumerated>STRING</enumerated>
            </basic>
            <basic name="unit"/>
            <basic name="unitSize"/>
            <basic name="createdAt">
                <column updatable="false"/>
            </basic>
        </attributes>
    </entity>

    <entity class="allmart.productservice.domain.category.Category">
        <table name="tbl_category"/>
        <attributes>
            <basic name="name">
                <column nullable="false" unique="true"/>
            </basic>
            <basic name="status">
                <column nullable="false"/>
                <enumerated>STRING</enumerated>
            </basic>
            <basic name="createdAt">
                <column updatable="false"/>
            </basic>
        </attributes>
    </entity>

</entity-mappings>
